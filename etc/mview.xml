<?xml version="1.0" encoding="UTF-8"?>
<!--
  Materialised-view subscriptions for the wiswes_product_push indexer.
  Magento's mview framework writes a row into the indexer change log every
  time one of the listed tables changes; the next "indexer:reindex" or
  scheduled run picks up only the changed entity_ids and ships those.

  Subscribed tables cover: product entity, EAV attribute values (text /
  varchar / int / decimal — names, descriptions, prices, status), and
  inventory stock. Adding a table here just enlarges the change log; it
  doesn't change what we ship — the indexer reads each id through the
  product repository and sends one batch.
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Mview/etc/mview.xsd">
    <view id="wiswes_product_push"
          class="WisWes\MCP\Model\Indexer\ProductPushIndexer"
          group="indexer">
        <subscriptions>
            <table name="catalog_product_entity" entity_column="entity_id"/>
            <table name="catalog_product_entity_int" entity_column="entity_id"/>
            <table name="catalog_product_entity_decimal" entity_column="entity_id"/>
            <table name="catalog_product_entity_varchar" entity_column="entity_id"/>
            <table name="catalog_product_entity_text" entity_column="entity_id"/>
            <table name="cataloginventory_stock_item" entity_column="product_id"/>
        </subscriptions>
    </view>
</config>
